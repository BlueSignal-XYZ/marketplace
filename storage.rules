rules_version = '2';

// Firebase Storage security rules for BlueSignal / WaterQuality.Trading.
//
// Root is locked down — access is granted per-path with explicit auth predicates.
// Matches the pattern used in database.rules.json (default-deny, per-node grants).

service firebase.storage {
  match /b/{bucket}/o {
    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Per-user avatar. Publicly readable (photoURL is surfaced in marketplace
    // profile cards). Writable only by the owner, only as an image, capped at 2MB.
    match /users/{uid}/avatar.{ext} {
      allow read: if true;
      allow write: if
        request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Listing images for marketplace listings. Owned by the seller.
    match /listings/{uid}/{listingId}/{imageId} {
      allow read: if true;
      allow write: if
        request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
