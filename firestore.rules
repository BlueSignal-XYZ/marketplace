rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Marketplace listings — public read, authenticated write
    match /listings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles — owner read/write only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles (alternate collection) — owner read/write only
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Quote requests - anyone can create, only admins read
    match /quote_requests/{document} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 0;
      allow read, update, delete: if false;
    }

    // Newsletter subscribers - anyone can create
    match /newsletter_subscribers/{document} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*');
      allow read, update, delete: if false;
    }

    // Contact form submissions
    match /contact_submissions/{document} {
      allow create: if request.resource.data.email is string;
      allow read, update, delete: if false;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
