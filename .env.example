# BlueSignal Marketplace — Environment Variables
# Copy this file to .env.local and fill in real values.
# Values can be found in: Firebase Console → Project Settings → General → Your apps → Config
#
# IMPORTANT: All variables MUST use the VITE_ prefix for Vite to expose them at build time.
# These same variables must also be set in Cloudflare Pages → Settings → Environment variables.

# ── Firebase Configuration (required for all modes) ──────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=

# ── Third-party API Keys ─────────────────────────────────────────────────────
VITE_ALCHEMY_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
VITE_LIVEPEER_API_KEY=

# ── Maps ──────────────────────────────────────────────────────────────────────
# Mapbox GL access token (required for project map and presale map)
VITE_MAPBOX_TOKEN=

# ── App Configuration ────────────────────────────────────────────────────────
# Backend Cloud Functions URL (defaults to production if not set)
VITE_SERVER_URL=
# Blockchain mode: "test" (Polygon Amoy) or "main" (Polygon mainnet)
VITE_BLOCKCHAIN_MODE=test
# Custom RPC endpoints (optional — falls back to public endpoints)
VITE_POLYGON_TESTNET_RPC=
VITE_POLYGON_MAINNET_RPC=
# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=

# ── Demo & Development ───────────────────────────────────────────────────────
# Enable demo mode globally (shows sample data across the platform; default: false)
VITE_DEMO_MODE=
# Show demo toggle in the Cloud header (auto-enabled in dev mode)
VITE_SHOW_DEMO_TOGGLE=
# Force mock API usage (default: false; set to "true" to enable)
VITE_USE_MOCK_API=
# Control mock data in Cloud console pages (default: false; set to "true" for mock data)
VITE_USE_MOCK_DATA=

# ── Build Metadata (optional) ────────────────────────────────────────────────
VITE_BUILD_VERSION=
VITE_DEBUG=
