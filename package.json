{
  "name": "bluesignal-marketplace",
  "version": "1.0.0",
  "description": "React SPA with tri-mode architecture: marketplace, cloud dashboard, and hardware landing page",
  "license": "BSL-1.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluesignal-xyz/marketplace.git"
  },
  "homepage": "https://waterquality.trading",
  "bugs": {
    "url": "https://github.com/bluesignal-xyz/marketplace/issues"
  },
  "author": "BlueSignal <hello@bluesignal.xyz> (https://bluesignal.xyz)",
  "keywords": [
    "water-quality",
    "marketplace",
    "iot",
    "react",
    "firebase",
    "blockchain",
    "polygon",
    "sensors",
    "environmental"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bash scripts/setup-env.sh && npm run build:wqt && npm run build:cloud && npm run build:landing",
    "preview": "vite preview",
    "build:wqt": "bash scripts/setup-env.sh && BUILD_TARGET=wqt node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --outDir dist-wqt && bash scripts/copy-seo-files.sh wqt",
    "build:cloud": "bash scripts/setup-env.sh && BUILD_TARGET=cloud node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --outDir dist-cloud && mv dist-cloud/cloud.html dist-cloud/index.html 2>/dev/null || true && bash scripts/copy-seo-files.sh cloud",
    "build:landing": "bash scripts/setup-env.sh && BUILD_TARGET=landing node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --outDir dist-landing && mv dist-landing/landing.html dist-landing/index.html 2>/dev/null || true && bash scripts/copy-seo-files.sh landing",
    "deploy:wqt": "npm run build:wqt && firebase deploy --only hosting:waterquality-trading",
    "deploy:cloud": "npm run build:cloud && firebase deploy --only hosting:cloud-bluesignal",
    "deploy:landing": "npm run build:landing && firebase deploy --only hosting:landing-bluesignal",
    "deploy:all": "npm run build && firebase deploy --only hosting && npm run cloudflare:trigger",
    "cloudflare:trigger": "bash scripts/cloudflare-deploy.sh hook",
    "cloudflare:trigger:wqt": "bash scripts/cloudflare-deploy.sh single wqt",
    "cloudflare:trigger:cloud": "bash scripts/cloudflare-deploy.sh single cloud",
    "cloudflare:trigger:landing": "bash scripts/cloudflare-deploy.sh single landing",
    "deploy:full:wqt": "npm run deploy:wqt && npm run cloudflare:trigger:wqt",
    "deploy:full:cloud": "npm run deploy:cloud && npm run cloudflare:trigger:cloud",
    "deploy:full:landing": "npm run deploy:landing && npm run cloudflare:trigger:landing",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=verbose",
    "test:integration": "firebase emulators:exec --only auth,database,functions 'npx vitest run --config vitest.integration.config.ts'",
    "emulators:start": "firebase emulators:start --only auth,database,functions",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "seed": "node scripts/seed-data.js",
    "seed:clear": "node scripts/seed-data.js --clear",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --write"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@livepeer/react": "^2.9.2",
    "@lottiefiles/react-lottie-player": "^3.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-google-maps/api": "^2.20.8",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tanstack/react-query": "^5.96.2",
    "@types/three": "^0.157.2",
    "alchemy-sdk": "^3.6.5",
    "axios": "^1.14.0",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
    "ethers": "^6.16.0",
    "firebase": "^12.11.0",
    "font-awesome": "^4.7.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "http-proxy-middleware": "^3.0.5",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.21.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.6.0",
    "react-loader-spinner": "^8.0.2",
    "react-lottie": "^1.2.10",
    "react-router-dom": "^7.14.0",
    "react-spring": "^10.0.3",
    "react-tabs": "^6.1.1",
    "react-tooltip": "^5.30.0",
    "styled-components": "^6.3.12",
    "three": "^0.183.2",
    "tus-js-client": "^4.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chart.js": "^4.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.13.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
