[Unit]
Description=BlueSignal BLE Commissioning Service
After=bluetooth.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bluesignal/firmware
ExecStart=/opt/bluesignal/firmware/venv/bin/python -m src.ble_service
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/bluesignal/firmware

[Install]
WantedBy=multi-user.target
